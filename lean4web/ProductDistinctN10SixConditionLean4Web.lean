def allCandidatePairsFail (As Bs : List (List Nat)) : Bool :=
  As.all (fun A => Bs.all (fun B => !productDistinct A B))

/-
Condition 5: for each frontier size, the displayed A-list is exactly the full
list of A candidates of that size.
-/
def allFrontierAListsCoveredN10 : Bool :=
  A_candidates_10 == subsetListsOfSize 10 10 &&
  A_candidates_8 == subsetListsOfSize 10 8 &&
  A_candidates_6 == subsetListsOfSize 10 6

/-
Condition 6: the B candidate lists are complete, and every A,B candidate pair
for each frontier size fails the product-distinct condition.
-/
def allFrontierBExistenceDeniedN10 : Bool :=
  B_candidates_3 == subsetListsOfSize 10 3 &&
  B_candidates_4 == subsetListsOfSize 10 4 &&
  B_candidates_5 == subsetListsOfSize 10 5 &&
  allCandidatePairsFail A_candidates_10 B_candidates_3 &&
  allCandidatePairsFail A_candidates_8 B_candidates_4 &&
  allCandidatePairsFail A_candidates_6 B_candidates_5

/-! ## Final six-condition theorem -/

/-
The final theorem is split as two lower-bound clauses and four upper-bound
clauses.

Lower-bound clauses:

1. The displayed witness
   A = [1, 2, 3, 4, 5, 6, 8],
   B = [1, 7, 9, 10]
   is product-distinct.

2. The same witness has value |A| * |B| = 28.

Upper-bound clauses:

3. The size pairs (|A|, |B|), with the larger side written first, whose product
   is greater than 28 are exactly the displayed list.

4. Every size pair in that displayed list contains one of the three frontier
   sizes:
   (10,3), (8,4), or (6,5).
   Therefore it is enough to rule out those three frontier sizes.

5. For those three frontier sizes, the displayed A-candidate lists are complete.

6. For those three frontier sizes, the displayed B-candidate lists are complete,
   and every displayed A,B candidate pair fails product-distinctness.
-/

theorem N10_six_conditions :
    productDistinct
      [1, 2, 3, 4, 5, 6, 8]
      [1, 7, 9, 10] = true ∧
    pairValue
      [1, 2, 3, 4, 5, 6, 8]
      [1, 7, 9, 10] = 28 ∧
    allSizePairsWithLargerSideFirstAbove 10 28 =
      [
      (6, 5), (6, 6), (7, 5), (7, 6), (7, 7), (8, 4),
      (8, 5), (8, 6), (8, 7), (8, 8), (9, 4), (9, 5),
      (9, 6), (9, 7), (9, 8), (9, 9), (10, 3), (10, 4),
      (10, 5), (10, 6), (10, 7), (10, 8), (10, 9), (10, 10)
    ] ∧
    ([
      (6, 5), (6, 6), (7, 5), (7, 6), (7, 7), (8, 4),
      (8, 5), (8, 6), (8, 7), (8, 8), (9, 4), (9, 5),
      (9, 6), (9, 7), (9, 8), (9, 9), (10, 3), (10, 4),
      (10, 5), (10, 6), (10, 7), (10, 8), (10, 9), (10, 10)
    ].all
      (fun p =>
        (decide (10 <= p.1) && decide (3 <= p.2)) ||
        (decide (8 <= p.1) && decide (4 <= p.2)) ||
        (decide (6 <= p.1) && decide (5 <= p.2)))) = true ∧
    allFrontierAListsCoveredN10 = true ∧
    allFrontierBExistenceDeniedN10 = true := by
  native_decide

#check N10_six_conditions
#print axioms N10_six_conditions

end ProductDistinctN10SixCondition
